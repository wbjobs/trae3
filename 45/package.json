{
  "name": "tactical-game",
  "version": "1.0.0",
  "description": "Multiplayer tactical game",
  "main": "dist/server/index.js",
  "scripts": {
    "start": "npm run build && concurrently \"npm run server\" \"npm run open-client\"",
    "server": "ts-node server/index.ts",
    "build": "tsc",
    "build:client": "tsc -p client/tsconfig.json",
    "build:server": "tsc -p server/tsconfig.json",
    "open-client": "start http://localhost:3000",
    "init-db": "ts-node scripts/initDb.ts",
    "init-data": "ts-node scripts/initData.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",

    "yaml": "^2.3.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6",
    "@types/express": "^4.17.21",

    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "concurrently": "^8.2.2"
  }
}
