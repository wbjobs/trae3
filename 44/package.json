  "author": "Distributed Computing Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "bull": "^4.12.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "sequelize": "^6.35.2",
    "axios": "^1.6.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "cluster": "^0.7.7",
    "os": "^0.1.2",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
