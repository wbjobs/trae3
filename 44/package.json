  "description": "分布式地质岩层参数并行插值计算系统",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:master": "node src/index.js --role master",
    "start:worker": "node src/index.js --role worker",
    "start:api": "node src/api/server.js",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint src/**/*.js",
    "dev": "nodemon src/index.js"
  },
  "keywords": [
