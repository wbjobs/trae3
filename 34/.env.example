NODE_ENV=development
PORT=8080

MONGODB_URI=mongodb://localhost:27017/cfd_scheduler
REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=your-secret-key-here

MAX_WORKERS=10
TASK_TIMEOUT=3600000
MAX_RETRY_ATTEMPTS=3

CFD_SOLVER_PATH=/path/to/openfoam
COMPUTE_SCRIPTS_PATH=./scripts

STORAGE_PATH=./storage
MAX_STORAGE_SIZE=10737418240

LOG_LEVEL=info
LOG_FILE=./logs/app.log
