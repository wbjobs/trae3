{
  "name": "cfd-distributed-scheduler",
  "version": "1.0.0",
  "description": "流体力学多相流场分布式计算调度系统",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "ts-node-dev --respawn --transpile-only src/server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "start": "node dist/server/index.js",
    "worker": "node dist/server/worker.js",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "antd": "^5.9.0",
    "archiver": "^6.0.1",
    "axios": "^1.5.0",
    "bull": "^4.11.5",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "dayjs": "^1.11.9",
    "dotenv": "^17.4.2",
    "echarts": "^5.4.3",
    "echarts-for-react": "^3.0.2",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "joi": "^17.10.0",
    "moment": "^2.29.4",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.15.0",
    "redis": "^4.6.8",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "uuid": "^14.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/archiver": "^5.3.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.5.9",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.6.0",
    "@typescript-eslint/parser": "^6.6.0",
    "@vitejs/plugin-react": "^4.0.4",
    "concurrently": "^8.2.1",
    "eslint": "^8.48.0",
    "jest": "^29.6.4",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2",
    "vite": "^4.4.9"
  }
}
