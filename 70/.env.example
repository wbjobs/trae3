# 配置中心 - Apollo
APOLLO_SERVER_URL=http://apollo-server:8080
APOLLO_APP_ID=your-app-id
APOLLO_CLUSTER=default
APOLLO_NAMESPACES=application
APOLLO_TOKEN=

# 配置中心 - Nacos
NACOS_SERVER_URL=http://nacos-server:8848
NACOS_NAMESPACE=
NACOS_GROUP=DEFAULT_GROUP
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# 版本数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=config_version
DB_CHARSET=utf8mb4

# 远程调用
REMOTE_TIMEOUT=30
REMOTE_RETRY_COUNT=3
REMOTE_RETRY_INTERVAL=2

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=configtool.log
