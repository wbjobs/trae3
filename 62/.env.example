PORT=3000
NODE_ENV=development

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

LOG_DIR=./logs
LOG_LEVEL=info

REGION_CLUSTERS=[{"id":"cn-north","name":"华北区","endpoint":"http://cluster-north.example.com","weight":100},{"id":"cn-south","name":"华南区","endpoint":"http://cluster-south.example.com","weight":80},{"id":"cn-east","name":"华东区","endpoint":"http://cluster-east.example.com","weight":90}]

QUEUE_NAMES=default,priority,bulk

MAX_RETRY_ATTEMPTS=3
RETRY_DELAY=1000

RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=1000
