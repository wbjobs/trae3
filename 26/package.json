{
  "name": "inspection-instrument-config",
  "version": "1.0.0",
  "description": "Industrial Inspection Instrument Parameter Configuration Tool",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "electron",
    "serialport",
    "industrial",
    "configuration"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "serialport": "^12.0.0",
    "@serialport/parser-inter-byte-timeout": "^12.0.0",
    "electron-store": "^8.1.0",
    "winston": "^3.11.0",
    "async": "^3.2.5",
    "crc": "^4.3.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.inspection.config",
    "productName": "巡检仪参数配置工具",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
